# Microsoft / Outlook (personal account) OAuth
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
# Must exactly match the "Redirect URI" registered in Azure (use https on Vercel)
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback

# 32-byte key (hex, 64 chars) used to encrypt the token cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-char-key

# Public base URL of the app (used for links). On Vercel this is set automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000
