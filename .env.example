# Microsoft / Outlook (personal account) OAuth
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback

# 32-byte key (hex, 64 chars) used to encrypt the stored Outlook token.
ENCRYPTION_KEY=replace-with-64-hex-char-key

# Local folder where invoice PDFs are saved
INVOICE_DIR=./invoices

# SQLite database path
DB_PATH=./data.db

# Endpoint that resolves Buyer Name from {invoiceNo, vendor}. Optional.
BUYER_ENDPOINT=https://example.com/api/buyer

# QuickBooks Online (Phase: Excel + QB push)
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/api/qb/callback
QB_ENV=sandbox

# Public base URL
PUBLIC_URL=http://localhost:3000
