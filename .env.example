# Microsoft / Outlook (personal account) OAuth
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback

# 32-byte key (hex, 64 chars) used to encrypt the stored Outlook token.
ENCRYPTION_KEY=replace-with-64-hex-char-key

# Public base URL
PUBLIC_URL=http://localhost:3000
